{
  "name": "@dantetekanem/pi-tasks",
  "version": "0.7.1",
  "description": "Strict task tracking and coordination for pi.",
  "author": "Leonardo Pereira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dantetekanem/pi-tasks.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "task",
    "tasks",
    "coordination"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.74.0"
  },
  "dependencies": {
    "typebox": "^1.1.34"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0",
    "@biomejs/biome": "^2.4.13",
    "vitest": "^4.1.5"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
